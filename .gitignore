# Environment & secrets — NEVER commit these
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
credentials.json
serviceAccount.json
config/secrets.yml
config/secrets.yaml

# Database
*.db
*.sqlite
*.sqlite3
shadow_dev.db

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environments
venv/
env/
ENV/
.venv/
.env/

# IDE & OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
.AppleDouble
.LSOverrideIcon

# Testing & Coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.coveragerc

# Logs
logs/
*.log

# Data / cache
data/vector_cache/
.cache/

# Distribution
*.whl
*.tar.gz
